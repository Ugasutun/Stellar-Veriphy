# Active network (testnet | mainnet | futurenet)
NEXT_PUBLIC_NETWORK=testnet

# Soroban contract addresses
NEXT_PUBLIC_ORACLE_CONTRACT_ID=
NEXT_PUBLIC_PROVENANCE_CONTRACT_ID=
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=
